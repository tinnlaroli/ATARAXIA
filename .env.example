# ATARAXIA — copia a .env y ajusta si necesitas otros puertos
# Evita conflictos con SMARTUR u otro stack en el mismo host

COMPOSE_PROJECT_NAME=ataraxia
VPS_IP=localhost

# Puertos expuestos en el host (nginx reverse proxy)
PLATAFORMA_HOST_PORT=8080
LANDING_HOST_PORT=4322
API_HOST_PORT=4100
MODELO_HOST_PORT=8100

# Stack API standalone (API/docker-compose.yml)
DB_HOST_PORT=5433
REDIS_HOST_PORT=6381
GRAFANA_HOST_PORT=4101

# Base de datos
DB_USER=postgres
DB_PASSWORD=12345678
DB_NAME=ataraxia

JWT_SECRET=change_me_in_production

# Reentrenamiento automático tras cada stress_assessment (API → MODELO /train-stress)
ML_AUTO_RETRAIN=1
ML_RETRAIN_DEBOUNCE_MS=15000
ML_RETRAIN_TIMEOUT_MS=120000

# MODELO / Kaggle (primera vez)
# KAGGLE_USERNAME=
# KAGGLE_KEY=
